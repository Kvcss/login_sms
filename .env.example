# Copie para .env e ajuste conforme necessario. (O servidor le variaveis de
# ambiente do sistema; este arquivo serve de referencia.)

# Porta do servidor
PORT=3000

# Provedor de SMS: "mock" (apenas loga o codigo no console) ou "twilio"
SMS_PROVIDER=mock

# Em modo dev, retorna o codigo de confirmacao no corpo da resposta 202.
# NUNCA use isso em producao. Facilita a gravacao do video / testes.
SMS_RETURN_CODE_IN_RESPONSE=true

# Tempo de validade do codigo de confirmacao (em minutos)
CONFIRMATION_TTL_MINUTES=10

# Caminho do banco SQLite (JDBC). Opcional.
# DB_URL=jdbc:sqlite:database.db

# --- Credenciais Twilio (necessarias somente se SMS_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
